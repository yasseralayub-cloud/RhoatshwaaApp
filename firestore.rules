rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email == "yasseralayub@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Menu Items Rules
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings Rules
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promotions Rules
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders Rules
    match /orders/{orderId} {
      // Anyone can read orders to allow real-time driver dispatcher syncing and guest tracking
      allow read: if true;
      
      // Anyone (guest checkouts) can place an order
      allow create: if isValidId(orderId) 
        && incoming().keys().hasAll(['id', 'customerName', 'customerPhone', 'tableOrDelivery', 'items', 'subtotal', 'tax', 'total', 'paymentMethod', 'status', 'whatsappSent', 'createdAt'])
        && incoming().customerName is string && incoming().customerName.size() <= 100
        && incoming().customerPhone is string && incoming().customerPhone.size() <= 30
        && incoming().tableOrDelivery in ['table', 'takeaway', 'delivery']
        && incoming().paymentMethod in ['cod', 'applepay', 'mada', 'transfer']
        && incoming().subtotal is number && incoming().subtotal >= 0
        && incoming().tax is number && incoming().tax >= 0
        && incoming().total is number && incoming().total >= 0;
        
      // Only administrators can update or delete orders, OR guest can transition status, OR driver can accept/update/broadcast delivery order
      allow update: if isAdmin() || (
        existing().status == 'pending' &&
        incoming().status in ['preparing', 'cancelled'] &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'whatsappSent'])
      ) || (
        // Driver self-assignment or broadcast assignment
        existing().tableOrDelivery == 'delivery' &&
        (!('driverId' in existing()) || existing().driverId == null || existing().driverId == 'broadcast') &&
        'driverId' in incoming() && incoming().driverId != null &&
        incoming().status == 'on_the_way' &&
        incoming().diff(existing()).affectedKeys().hasOnly(['driverId', 'driverName', 'driverPhone', 'status'])
      ) || (
        // Driver updating their assigned order status
        existing().tableOrDelivery == 'delivery' &&
        'driverId' in existing() && existing().driverId != null &&
        incoming().driverId == existing().driverId &&
        incoming().status in ['on_the_way', 'delivered'] &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      
      // Allow administrators to delete any order, or allow assigned drivers to delete completed deliveries
      allow delete: if isAdmin() || (
        existing().tableOrDelivery == 'delivery' &&
        'driverId' in existing() && existing().driverId != null
      );
    }

    // Drivers Rules
    match /drivers/{driverId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'suspendedUntil', 'completedCount', 'totalEarnings']) &&
        incoming().status in ['available', 'busy', 'suspended']
      );
    }

    // Pending Drivers Rules
    match /pending_drivers/{pendingId} {
      allow read: if isAdmin();
      allow create: if isValidId(pendingId)
        && incoming().keys().hasAll(['name', 'phone', 'carRegistrationImg', 'status', 'createdAt'])
        && incoming().name is string && incoming().name.size() <= 200
        && incoming().phone is string && incoming().phone.size() <= 100
        && incoming().carRegistrationImg is string
        && incoming().status == 'pending'
        && incoming().createdAt is string;
      allow update, delete: if isAdmin();
    }

    // Admins List
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users Rules
    match /users/{phone} {
      allow read: if true;
      allow create, update: if isValidId(phone)
        && incoming().keys().hasAll(['name', 'phone'])
        && incoming().name is string && incoming().name.size() <= 100
        && incoming().phone == phone
        && (!('addresses' in incoming()) || incoming().addresses is list);
      allow delete: if isAdmin();
    }

    // Support Tickets Rules
    match /support_tickets/{ticketId} {
      allow read, write: if true;
    }
  }
}
